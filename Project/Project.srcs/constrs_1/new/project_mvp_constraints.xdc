set_property -dict { PACKAGE_PIN C6    IOSTANDARD LVCMOS33 } [get_ports { data_out[4] }]; #IO_L1P_T0_AD4P_35 Sch=vga_g[0]
set_property -dict { PACKAGE_PIN A5    IOSTANDARD LVCMOS33 } [get_ports { data_out[5] }]; #IO_L3N_T0_DQS_AD5N_35 Sch=vga_g[1]
